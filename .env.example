# AKAB Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
MCP_SERVER_NAME=AKAB-Dev
PORT=8000
LOG_LEVEL=INFO

# Data Storage
DATA_PATH=/data/akab

# API Keys for Remote Providers (Optional)
# Leave blank if you only want to use local execution

# OpenAI API Key for GPT models
OPENAI_API_KEY=

# Anthropic API Key for Claude models via API
ANTHROPIC_API_KEY=

# Google API Key for Gemini models
GOOGLE_API_KEY=

# Future: Additional provider keys
# MISTRAL_API_KEY=
# COHERE_API_KEY=
