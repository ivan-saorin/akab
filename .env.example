# AKAB Environment Variables
# Copy this file to .env and fill in your API keys

# Anthropic API Key (required for anthropic_* providers)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (required for openai_* providers)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google API Key (required for google_* providers)
# Get yours at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# === Model Configuration ===
# Format: <PROVIDER>_<SIZE>_MODEL=<model-name>

# Anthropic Models
ANTHROPIC_XS_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_S_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_M_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_L_MODEL=claude-3-7-sonnet-20250219
ANTHROPIC_XL_MODEL=claude-sonnet-4-20250514
ANTHROPIC_XXL_MODEL=claude-opus-4-20250514

# OpenAI Models
OPENAI_XS_MODEL=gpt-4o-mini
OPENAI_S_MODEL=gpt-4o-mini
OPENAI_M_MODEL=gpt-4o
OPENAI_L_MODEL=gpt-4o
OPENAI_XL_MODEL=o1-preview
OPENAI_XXL_MODEL=o1

# Google Models
GOOGLE_XS_MODEL=gemini-1.5-flash
GOOGLE_S_MODEL=gemini-1.5-flash
GOOGLE_M_MODEL=gemini-1.5-pro
GOOGLE_L_MODEL=gemini-1.5-pro
GOOGLE_XL_MODEL=gemini-1.5-pro
GOOGLE_XXL_MODEL=gemini-1.5-pro

# Groq Models
GROQ_XS_MODEL=llama-3.2-3b-preview
GROQ_S_MODEL=llama-3.2-7b-preview
GROQ_M_MODEL=llama-3.2-70b-preview
GROQ_L_MODEL=llama-3.2-70b-preview
GROQ_XL_MODEL=llama-3.2-70b-preview
GROQ_XXL_MODEL=llama-3.2-70b-preview


# Optional: Custom base URLs for API endpoints
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# Optional: Logging level
LOG_LEVEL=INFO

# Optional: Data storage path (default: ./akab_data)
# AKAB_DATA_PATH=./akab_data
